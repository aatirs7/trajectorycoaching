# MentorReach — environment.
# Copy to .env.local and fill in. .env.local is gitignored; this file is committed.
#
# TWO TIERS (see src/lib/env.ts):
#   REQUIRED — the app won't boot without these.
#   OPTIONAL — an integration. Missing = that feature is disabled, with an honest
#              message in the UI. The rest of the app is unaffected, and it still
#              builds. /admin/integrations shows what's live.


# =============================================================================
# REQUIRED
# =============================================================================

# --- Neon ---------------------------------------------------------------------
# TWO strings, differing only by "-pooler" in the host:
#   DATABASE_URL          POOLED  — the app
#   DATABASE_URL_UNPOOLED DIRECT  — drizzle-kit (DDL must not go through PgBouncer)
DATABASE_URL=""
DATABASE_URL_UNPOOLED=""

# --- Clerk --------------------------------------------------------------------
# Phase 0/1 use DEV keys (pk_test_/sk_test_) even on Vercel: a Clerk production
# instance needs DNS on a real domain, which is blocked on spec §14.5.
#
# ⚠️ REQUIRED AND NOT A KEY — Clerk Dashboard → Sessions → Customize session token
#    → Claims editor:   { "metadata": "{{user.public_metadata}}" }
#    Without it sessionClaims.metadata.role is undefined and every role check fails.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Clerk Dashboard → Webhooks → <your-url>/api/webhooks/clerk
# Subscribe: user.created, user.updated, user.deleted
CLERK_WEBHOOK_SIGNING_SECRET=""


# =============================================================================
# OPTIONAL — integrations. Each one activates when its keys appear.
# =============================================================================

# --- Stripe Connect (§10) -----------------------------------------------------
# Needs Connect ENABLED on the platform account (Express connected accounts).
# Missing STRIPE_SECRET_KEY      → booking disabled, Book button explains why.
# Missing STRIPE_WEBHOOK_SECRET  → payments would take money but never create a
#                                  session. Booking is effectively broken. Set both.
# Webhook endpoint: <your-url>/api/webhooks/stripe
# Events: checkout.session.completed, charge.refunded, account.updated
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Zoom (§9) ----------------------------------------------------------------
# Server-to-Server OAuth app on one platform Zoom account. The native scheduler
# creates a meeting per booking. Create the app at marketplace.zoom.us → Develop →
# "Server-to-Server OAuth", grant the meeting:write scopes, and copy the three below.
ZOOM_ACCOUNT_ID=""
ZOOM_CLIENT_ID=""
ZOOM_CLIENT_SECRET=""

# --- Resend (§12) -------------------------------------------------------------
# Missing → emails are skipped and logged. In-app notifications still work; they
# are the durable record. EMAIL_FROM must be on a domain verified in Resend.
RESEND_API_KEY=""
EMAIL_FROM="MentorReach <hello@mentorreach.com>"

# --- Cron (§11) ---------------------------------------------------------------
# Protects /api/cron, which marks sessions completed and sends 24h reminders.
# Vercel Cron sends `Authorization: Bearer $CRON_SECRET` (see vercel.json).
# Missing → the endpoint 404s and sessions never move to `completed`.
# Generate one:  openssl rand -hex 32
CRON_SECRET=""

# --- Misc ---------------------------------------------------------------------
# Gates /api/health in production (x-health-token header).
HEALTH_CHECK_TOKEN=""


# =============================================================================
# App
# =============================================================================
# MUST match the deployed origin in production — used to build Stripe return URLs
# and links in emails.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/onboarding/role"
